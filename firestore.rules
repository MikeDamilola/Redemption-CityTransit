// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: users
// Document ID: {userId}
// Fields:
//   - uid: string (required)
//   - email: string (required)
//   - displayName: string
//   - role: string (passenger | driver)
//   - balance: number (required)
//   - createdAt: number (required)
//   - photoURL: string
//   - vehicleNumber: string
//   - qrCodeData: string
//
// Collection: transactions
// Document ID: {transactionId}
// Fields:
//   - id: string (required)
//   - fromId: string (required)
//   - fromName: string
//   - toId: string (required)
//   - toName: string
//   - amount: number (required)
//   - type: string (purchase | payment | transfer)
//   - timestamp: number (required)
//   - status: string (completed | pending | failed)
//
// Collection: rides
// Document ID: {rideId}
// Fields:
//   - id: string (required)
//   - passengerId: string (required)
//   - passengerName: string (required)
//   - driverId: string
//   - driverName: string
//   - status: string (pending | accepted | completed | cancelled)
//   - pickup: string (required)
//   - destination: string (required)
//   - fare: number (required)
//   - timestamp: number (required)
//
// ===============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
             request.auth.token.email == 'dadadammy4141@gmail.com' && 
             request.auth.token.email_verified == true;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role', 'balance', 'createdAt']) &&
             data.uid is string &&
             data.email is string &&
             (data.role in ['passenger', 'driver'] || data.role == null) &&
             data.balance is number &&
             data.createdAt is number &&
             (data.isAvailable == null || data.isAvailable is bool);
    }

    function isValidTransaction(data) {
      return data.keys().hasAll(['id', 'fromId', 'toId', 'amount', 'type', 'timestamp', 'status']) &&
             data.id is string &&
             data.fromId is string &&
             data.toId is string &&
             data.amount is number &&
             data.amount > 0 &&
             data.type in ['purchase', 'payment', 'transfer'] &&
             data.timestamp is number &&
             data.status in ['completed', 'pending', 'failed'];
    }

    function isValidRide(data) {
      return data.keys().hasAll(['id', 'passengerId', 'passengerName', 'status', 'pickup', 'destination', 'fare', 'timestamp', 'driverId', 'driverName']) &&
             data.id is string &&
             data.passengerId is string &&
             data.passengerName is string &&
             (data.driverId == null || data.driverId is string) &&
             (data.driverName == null || data.driverName is string) &&
             data.status in ['pending', 'accepted', 'completed', 'cancelled'] &&
             data.pickup is string &&
             data.destination is string &&
             data.fare is number &&
             data.timestamp is number &&
             (data.get('acceptedAt', 0) == 0 || data.get('acceptedAt', 0) is number) &&
             (data.get('completedAt', 0) == 0 || data.get('completedAt', 0) is number);
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId) && isValidUser(request.resource.data) && request.resource.data.balance == 0;
      allow update: if isAuthenticated() && (
        isOwner(userId) || 
        isAdmin() ||
        (
          // Allow others to update balance (e.g. paying a driver or admin reset)
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['balance'])
        )
      );
      allow delete: if isOwner(userId) || isAdmin();
    }

    match /transactions/{transactionId} {
      allow read: if isAuthenticated() && (isAdmin() || request.auth.uid == resource.data.fromId || request.auth.uid == resource.data.toId);
      allow create: if isAuthenticated() && 
                      request.auth.uid == request.resource.data.fromId && 
                      isValidTransaction(request.resource.data);
      allow delete: if isAdmin();
    }

    match /rides/{rideId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && 
                     request.auth.uid == request.resource.data.passengerId && 
                     isValidRide(request.resource.data);
      allow update: if isAuthenticated() && isValidRide(request.resource.data) && (
        // Passenger can cancel their pending ride
        (request.auth.uid == resource.data.passengerId && resource.data.status == 'pending' && request.resource.data.status == 'cancelled') ||
        // Driver can accept a pending ride
        (resource.data.status == 'pending' && request.resource.data.status == 'accepted' && request.resource.data.driverId == request.auth.uid) ||
        // Driver can complete an accepted ride
        (resource.data.status == 'accepted' && request.auth.uid == resource.data.driverId && request.resource.data.status == 'completed')
      );
      allow delete: if isAdmin() || (isAuthenticated() && request.auth.uid == resource.data.passengerId && resource.data.status == 'pending');
    }
  }
}
