{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores user profile information and balance.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Unique user ID from Firebase Auth" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["passenger", "driver"] },
        "balance": { "type": "number", "description": "Token balance in units" },
        "createdAt": { "type": "number" },
        "photoURL": { "type": "string", "format": "uri" },
        "vehicleNumber": { "type": "string" },
        "qrCodeData": { "type": "string" },
        "isAvailable": { "type": "boolean", "description": "Whether a driver is currently taking orders" }
      },
      "required": ["uid", "email", "role", "balance", "createdAt"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "Records of token purchases and payments.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "fromId": { "type": "string" },
        "fromName": { "type": "string" },
        "toId": { "type": "string" },
        "toName": { "type": "string" },
        "amount": { "type": "number" },
        "type": { "type": "string", "enum": ["purchase", "payment", "transfer"] },
        "timestamp": { "type": "number" },
        "status": { "type": "string", "enum": ["completed", "pending", "failed"] }
      },
      "required": ["id", "fromId", "toId", "amount", "type", "timestamp", "status"]
    },
    "Ride": {
      "title": "Ride",
      "description": "Ride bookings between commuters and drivers.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "passengerId": { "type": "string" },
        "passengerName": { "type": "string" },
        "driverId": { "type": "string" },
        "driverName": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "accepted", "completed", "cancelled"] },
        "pickup": { "type": "string" },
        "destination": { "type": "string" },
        "fare": { "type": "number" },
        "timestamp": { "type": "number" },
        "acceptedAt": { "type": "number" },
        "completedAt": { "type": "number" }
      },
      "required": ["id", "passengerId", "passengerName", "status", "pickup", "destination", "fare", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profile documents"
    },
    "/transactions/{transactionId}": {
      "schema": "Transaction",
      "description": "Transaction records"
    },
    "/rides/{rideId}": {
      "schema": "Ride",
      "description": "Ride booking records"
    }
  }
}
